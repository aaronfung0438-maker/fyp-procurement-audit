# Copy this file to secrets.toml and fill in real values.
# The real secrets.toml MUST NOT be committed to git.

# The Google Sheets file ID — the bit between /d/ and /edit in the URL.
spreadsheet_id = "1AbCdEfGhIjKlMnOpQrStUvWxYz0123456789ABCDEF"

[gcp_service_account]
type = "service_account"
project_id = "your-gcp-project-id"
private_key_id = "abc123def456..."
private_key = """-----BEGIN PRIVATE KEY-----
MIIEvQIBADANBgkqhkiG9w0BAQEFAASCBKcwggSjAgEAAoIBAQ...
...replace with the real multi-line key from credentials.json...
-----END PRIVATE KEY-----
"""
client_email = "experiment-bot@your-gcp-project-id.iam.gserviceaccount.com"
client_id = "123456789012345678901"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/experiment-bot%40your-gcp-project-id.iam.gserviceaccount.com"
universe_domain = "googleapis.com"
